{
  "title": "OTel Demo – Logs Explorer",
  "uid": "otel-logs-explorer",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["otel", "logs", "loki"],
  "panels": [
    {
      "id": 1,
      "title": "Log Volume",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (detected_level) (count_over_time({service_name=\"otel-demo-app\"}[1m]))",
          "legendFormat": "{{detected_level}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 2,
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true
      },
      "targets": [
        {
          "expr": "{service_name=\"otel-demo-app\", detected_level=\"error\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 3,
      "title": "All Application Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{service_name=\"otel-demo-app\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 4,
      "title": "Log Rate by Level",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (detected_level) (count_over_time({service_name=\"otel-demo-app\"}[5m]))",
          "legendFormat": "{{detected_level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            {"color": "blue", "value": null},
            {"color": "yellow", "value": 10},
            {"color": "red", "value": 50}
          ]}
        }
      }
    },
    {
      "id": 5,
      "title": "OTel Collector Logs",
      "type": "logs",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{job=\"otel-collector\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
